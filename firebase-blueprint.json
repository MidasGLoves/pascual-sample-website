{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A service request lead from a customer.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the customer"
        },
        "address": {
          "type": "string",
          "description": "Full physical address for the service"
        },
        "email": {
          "type": "string",
          "description": "Email address of the customer"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the customer"
        },
        "service": {
          "type": "string",
          "description": "Type of service needed"
        },
        "message": {
          "type": "string",
          "description": "Brief description of the issue"
        },
        "status": {
          "type": "string",
          "enum": ["new", "contacted", "resolved"],
          "description": "Current status of the lead"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the lead was created"
        }
      },
      "required": ["name", "address", "service", "status", "date"]
    },
    "Recipient": {
      "title": "Recipient",
      "description": "An email address that receives lead notifications.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The email address"
        },
        "addedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "addedAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/Lead"
      },
      "description": "Collection of service request leads."
    },
    "/recipients/{recipientId}": {
      "schema": {
        "$ref": "#/entities/Recipient"
      },
      "description": "Collection of email recipients for notifications."
    }
  }
}
